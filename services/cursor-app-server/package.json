{
  "name": "@clawdex/cursor-app-server",
  "version": "0.1.0",
  "description": "App-server shaped JSON-RPC adapter for Cursor agents.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cursor-app-server": "dist/stdio.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/stdio.ts",
    "start": "node dist/stdio.js",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json && chmod +x dist/stdio.js",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cursor/sdk": "1.0.11",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "globals": "^16.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^4.1.0"
  }
}
