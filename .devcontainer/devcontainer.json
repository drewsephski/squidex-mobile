{
  "name": "Clawdex Mobile",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/rust:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [8787, 8788],
  "portsAttributes": {
    "8787": {
      "label": "Clawdex Bridge",
      "onAutoForward": "silent"
    },
    "8788": {
      "label": "Clawdex Browser Preview",
      "onAutoForward": "silent"
    }
  },
  "updateContentCommand": "npm install --include=dev --prefer-offline --no-audit --fund=false && npm run codespaces:bootstrap -- --prepare-only",
  "postStartCommand": "bash -lc 'nohup npm run codespaces:bootstrap > .bridge-bootstrap.log 2>&1 < /dev/null &'",
  "waitFor": "updateContentCommand"
}
